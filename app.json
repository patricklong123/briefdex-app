{
  "expo": {
    "name": "Briefdex",
    "slug": "briefdex-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "briefdex",
    "userInterfaceStyle": "dark",
    "splash": {
      "resizeMode": "contain",
      "backgroundColor": "#0a1a10"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.briefdex.app",
      "buildNumber": "2",
      "infoPlist": {
        "UIBackgroundModes": [
          "audio",
          "audio"
        ],
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.briefdex.app",
      "adaptiveIcon": {
        "backgroundColor": "#0a1a10"
      },
      "permissions": [
        "android.permission.MODIFY_AUDIO_SETTINGS"
      ]
    },
    "plugins": [
      "expo-font",
      [
        "expo-av",
        {
          "microphonePermission": false
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "d05fc3f4-a3fc-44bd-9bf4-8265417e528f"
      }
    }
  }
}
