{
  "expo": {
    "name": "Briefdex",
    "slug": "briefdex-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "briefdex",
    "userInterfaceStyle": "dark",
    "splash": {
      "resizeMode": "contain",
      "backgroundColor": "#0a1a10"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.briefdex.app",
      "infoPlist": {
        "UIBackgroundModes": ["audio"]
      }
    },
    "android": {
      "package": "com.briefdex.app",
      "adaptiveIcon": {
        "backgroundColor": "#0a1a10"
      }
    },
    "plugins": [
      "expo-font",
      [
        "expo-av",
        {
          "microphonePermission": false
        }
      ]
    ]
  }
}
